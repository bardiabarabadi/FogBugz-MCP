{
  "name": "fogbugz-mcp",
  "version": "1.1.0",
  "description": "MCP server for FogBugz (Manuscript) – search cases, view details, manage lifecycle, and more.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fogbugz-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "fogbugz", "manuscript", "cursor", "claude"],
  "author": "Bardia Barabadi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bardiabarabadi/FogBugz-MCP.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
